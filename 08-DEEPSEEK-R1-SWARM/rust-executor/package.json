{
    "name": "deepseek-swarm-executor",
    "version": "1.0.0",
    "main": "index.js",
    "types": "index.d.ts",
    "napi": {
        "name": "swarm_executor",
        "triples": {
            "defaults": true,
            "additional": [
                "x86_64-pc-windows-msvc",
                "aarch64-unknown-linux-gnu",
                "x86_64-unknown-linux-gnu",
                "x86_64-apple-darwin",
                "aarch64-apple-darwin"
            ]
        }
    },
    "scripts": {
        "build": "napi build --platform --release",
        "build:debug": "napi build --platform",
        "artifacts": "napi artifacts"
    },
    "devDependencies": {
        "@napi-rs/cli": "^2.18.0"
    }
}