    QANTUM_MIND_VERSION=1.0.0-QAntum \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# Run as non-root user
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nodejs
USER nodejs

# Start application
CMD ["node", "index.js"]
