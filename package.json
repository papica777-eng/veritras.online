{
  "name": "qantum-framework",
  "version": "1.0.0-QAntum",
  "description": "AI-powered self-healing tests, autonomous B2B sales, and cognitive crypto arbitrage in one TypeScript framework",
  "main": "src/index.ts",
  "bin": {
    "QAntum": "./QAntum-cli.js"
  },
  "scripts": {
    "start": "npx ts-node src/index.ts",
    "dev": "npx ts-node --watch src/index.ts",
    "build": "tsc --outDir dist",
    "dashboard": "node dashboard/server.js",
    "reaper": "npx ts-node PRIVATE-CORE/reaper-live-server.ts",
    "singularity": "npx ts-node scripts/singularity-launcher.ts",
    "test": "npx vitest run",
    "lint": "npx eslint src --ext .ts",
    "upgrade": "node QAntum-cli.js upgrade",
    "analyze": "ts-node JS-Framework/scripts/deduplicate-analyze.ts .",
    "magnet": "ts-node JS-Framework/scripts/neural-core-magnet.ts . ./analysis-output/TAXONOMY.json ./analysis-output",
    "integrate": "ts-node JS-Framework/scripts/qantum-integrator.ts ./analysis-output ./analysis-output"
  },
  "keywords": [
    "ai",
    "testing",
    "self-healing",
    "autonomous",
    "sales-automation",
    "crypto-arbitrage",
    "typescript",
    "framework",
    "saas"
  ],
  "author": "Dimitar Prodromov <founder@QAntum.empire>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/QAntum-empire/QAntum-framework"
  },
  "homepage": "https://QAntum.empire",
  "bugs": {
    "url": "https://github.com/QAntum-empire/QAntum-framework/issues",
    "email": "founder@QAntum.empire"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@pinecone-database/pinecone": "^7.1.0",
    "@tensorflow-models/universal-sentence-encoder": "^1.3.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@types/commander": "^2.12.0",
    "@types/pdfkit": "^0.17.5",
    "axios": "^1.13.5",
    "better-sqlite3": "^12.6.2",
    "body-parser": "^2.2.2",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "playwright": "^1.42.1",
    "puppeteer": "^24.2.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "puppeteer-screen-recorder": "^3.0.6",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.19.33",
    "@types/ws": "^8.5.0",
    "ts-node": "^10.9.0",
    "twitter-api-v2": "^1.29.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "overrides": {
    "puppeteer": "^24.2.0",
    "puppeteer-screen-recorder": {
      "puppeteer": "$puppeteer"
    }
  }
}
