<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>VERITRAS — Sovereign AI Ecosystem | QAntum · AETERNA · CHRONOS</title>
    <meta name="description"
        content="Three autonomous AI systems by Dimitar Prodromov. QAntum Prime (The AI That Tests Itself), AETERNA Logos (Sovereign Infrastructure), CHRONOS (Trading Intelligence with 4-valued Catuskoti logic). 715,861 lines. Zero entropy.">
    <meta property="og:title" content="VERITRAS — Three Systems. One Architect.">
    <meta property="og:description"
        content="Self-healing QA, sovereign infrastructure, and trading intelligence powered by retrocausal analysis.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://veritras.online">
    <link rel="canonical" href="https://veritras.online">
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap"
        rel="stylesheet">
    <style>
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        :root {
            --bg: #030306;
            --bg2: #080810;
            --card: rgba(12, 12, 22, 0.7);
            --bdr: rgba(255, 255, 255, 0.06);
            --txt: #eef;
            --dim: #7779aa;
            --mut: #445;
            --cyan: #00e5ff;
            --purple: #b24dff;
            --gold: #ffd700;
            --green: #00ff88;
            --red: #ff4466;
            --pink: #ff66aa
        }

        html {
            scroll-behavior: smooth
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--txt);
            overflow-x: hidden;
            line-height: 1.6
        }

        .bg-fx {
            position: fixed;
            inset: 0;
            z-index: 0;
            background: radial-gradient(ellipse 900px 700px at 15% 25%, rgba(0, 229, 255, .04), transparent), radial-gradient(ellipse 700px 900px at 85% 75%, rgba(178, 77, 255, .04), transparent), radial-gradient(ellipse 500px 500px at 50% 50%, rgba(255, 215, 0, .02), transparent)
        }

        .grid-bg {
            position: fixed;
            inset: 0;
            z-index: 0;
            background-image: linear-gradient(rgba(255, 255, 255, .012) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, .012) 1px, transparent 1px);
            background-size: 80px 80px
        }

        /* NAV */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 100;
            padding: 1rem 2.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(3, 3, 6, .88);
            backdrop-filter: blur(24px);
            border-bottom: 1px solid var(--bdr)
        }

        .logo {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--cyan);
            text-decoration: none;
            letter-spacing: 2px
        }

        .logo span {
            color: var(--mut);
            font-weight: 400;
            font-size: .85rem
        }

        .nav-r {
            display: flex;
            gap: 1.8rem;
            align-items: center
        }

        .nav-r a {
            color: var(--dim);
            text-decoration: none;
            font-size: .85rem;
            font-weight: 500;
            transition: color .3s
        }

        .nav-r a:hover {
            color: var(--cyan)
        }

        .nav-cta {
            background: linear-gradient(135deg, var(--cyan), var(--purple));
            color: #000 !important;
            padding: .5rem 1.2rem;
            border-radius: 8px;
            font-weight: 700 !important
        }

        /* HERO */
        .hero {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 7rem 2rem 4rem
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            padding: .45rem 1rem;
            border: 1px solid rgba(0, 229, 255, .2);
            border-radius: 100px;
            font-size: .75rem;
            color: var(--cyan);
            font-family: 'JetBrains Mono', monospace;
            margin-bottom: 2rem;
            background: rgba(0, 229, 255, .04);
            animation: bpulse 3s infinite
        }

        @keyframes bpulse {

            0%,
            100% {
                box-shadow: 0 0 0 0 rgba(0, 229, 255, .1)
            }

            50% {
                box-shadow: 0 0 20px 5px rgba(0, 229, 255, .04)
            }
        }

        .dot {
            width: 8px;
            height: 8px;
            background: var(--green);
            border-radius: 50%;
            animation: dp 2s infinite
        }

        @keyframes dp {

            0%,
            100% {
                opacity: 1
            }

            50% {
                opacity: .4
            }
        }

        .hero h1 {
            font-size: clamp(2.8rem, 7vw, 5.5rem);
            font-weight: 900;
            letter-spacing: -3px;
            line-height: 1.05;
            margin-bottom: 1.5rem
        }

        .gr {
            background: linear-gradient(135deg, var(--cyan), var(--purple), var(--gold));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text
        }

        .hero-sub {
            font-size: clamp(1rem, 2.2vw, 1.3rem);
            color: var(--dim);
            max-width: 680px;
            margin-bottom: 3rem;
            font-weight: 300
        }

        .hero-sub strong {
            color: var(--cyan);
            font-weight: 600
        }

        .hctas {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            justify-content: center;
            margin-bottom: 3.5rem
        }

        .btn-p {
            background: linear-gradient(135deg, var(--cyan), var(--purple));
            color: #000;
            padding: .9rem 2.2rem;
            border: none;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all .3s;
            text-decoration: none
        }

        .btn-p:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 40px rgba(0, 229, 255, .3)
        }

        .btn-s {
            background: transparent;
            color: var(--txt);
            padding: .9rem 2.2rem;
            border: 1px solid var(--bdr);
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 500;
            text-decoration: none;
            transition: all .3s
        }

        .btn-s:hover {
            border-color: var(--cyan);
            background: rgba(0, 229, 255, .04)
        }

        /* STATS BAR */
        .stats {
            display: flex;
            gap: 2.5rem;
            padding: 1rem 2rem;
            border: 1px solid var(--bdr);
            border-radius: 16px;
            background: var(--card);
            backdrop-filter: blur(20px);
            font-family: 'JetBrains Mono', monospace;
            font-size: .8rem;
            flex-wrap: wrap;
            justify-content: center
        }

        .stat {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: .2rem
        }

        .stat-l {
            color: var(--mut);
            font-size: .65rem;
            text-transform: uppercase;
            letter-spacing: 1px
        }

        .stat-v {
            font-weight: 700;
            font-size: .95rem
        }

        .c {
            color: var(--cyan)
        }

        .p {
            color: var(--purple)
        }

        .g {
            color: var(--gold)
        }

        .gn {
            color: var(--green)
        }

        /* SECTIONS */
        section {
            position: relative;
            z-index: 1;
            padding: 5rem 2rem;
            max-width: 1300px;
            margin: 0 auto
        }

        .slbl {
            font-family: 'JetBrains Mono', monospace;
            font-size: .7rem;
            color: var(--purple);
            letter-spacing: 3px;
            text-transform: uppercase;
            margin-bottom: .8rem
        }

        .stitle {
            font-size: clamp(1.8rem, 4vw, 2.8rem);
            font-weight: 800;
            margin-bottom: .8rem;
            letter-spacing: -1px
        }

        .sdesc {
            color: var(--dim);
            font-size: 1.05rem;
            max-width: 620px;
            margin-bottom: 2.5rem
        }

        /* 3 SERVICES GRID */
        .srv-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem
        }

        .srv {
            background: var(--card);
            border: 1px solid var(--bdr);
            border-radius: 20px;
            padding: 2.5rem 2rem;
            backdrop-filter: blur(12px);
            transition: all .5s cubic-bezier(.19, 1, .22, 1);
            display: flex;
            flex-direction: column;
            text-decoration: none;
            color: inherit;
            position: relative;
            overflow: hidden
        }

        .srv::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            opacity: 0;
            transition: opacity .5s
        }

        .srv:hover {
            transform: translateY(-6px)
        }

        .srv:hover::before {
            opacity: 1
        }

        .srv:nth-child(1):hover {
            border-color: rgba(0, 229, 255, .2);
            box-shadow: 0 16px 50px rgba(0, 229, 255, .08)
        }

        .srv:nth-child(1)::before {
            background: linear-gradient(90deg, transparent, var(--cyan), transparent)
        }

        .srv:nth-child(2):hover {
            border-color: rgba(178, 77, 255, .2);
            box-shadow: 0 16px 50px rgba(178, 77, 255, .08)
        }

        .srv:nth-child(2)::before {
            background: linear-gradient(90deg, transparent, var(--purple), transparent)
        }

        .srv:nth-child(3):hover {
            border-color: rgba(255, 215, 0, .2);
            box-shadow: 0 16px 50px rgba(255, 215, 0, .08)
        }

        .srv:nth-child(3)::before {
            background: linear-gradient(90deg, transparent, var(--gold), transparent)
        }

        .srv-icon {
            width: 50px;
            height: 50px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 1.5rem
        }

        .srv-icon.ic {
            background: rgba(0, 229, 255, .08);
            border: 1px solid rgba(0, 229, 255, .15)
        }

        .srv-icon.ip {
            background: rgba(178, 77, 255, .08);
            border: 1px solid rgba(178, 77, 255, .15)
        }

        .srv-icon.ig {
            background: rgba(255, 215, 0, .08);
            border: 1px solid rgba(255, 215, 0, .15)
        }

        .srv-num {
            font-family: 'JetBrains Mono', monospace;
            font-size: .6rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            margin-bottom: .6rem
        }

        .srv h2 {
            font-size: 1.6rem;
            font-weight: 800;
            margin-bottom: .6rem
        }

        .srv-desc {
            color: var(--dim);
            font-size: .92rem;
            line-height: 1.6;
            margin-bottom: 1.5rem;
            flex-grow: 1
        }

        .srv-feats {
            list-style: none;
            margin-bottom: 1.5rem
        }

        .srv-feats li {
            font-size: .87rem;
            color: var(--dim);
            padding: .45rem 0;
            display: flex;
            gap: .6rem;
            align-items: center;
            border-bottom: 1px solid rgba(255, 255, 255, .025)
        }

        .srv-feats li:last-child {
            border: none
        }

        .srv-price {
            display: flex;
            align-items: baseline;
            gap: .3rem;
            margin-bottom: 1.2rem
        }

        .srv-price .fr {
            font-size: .75rem;
            color: var(--mut)
        }

        .srv-price .am {
            font-size: 2.2rem;
            font-weight: 900;
            letter-spacing: -1px
        }

        .srv-price .pr {
            font-size: .8rem;
            color: var(--mut)
        }

        .srv-cta {
            display: block;
            width: 100%;
            padding: .85rem;
            border-radius: 10px;
            text-align: center;
            font-weight: 700;
            font-size: .9rem;
            text-decoration: none;
            transition: all .3s
        }

        .sc-c {
            background: rgba(0, 229, 255, .08);
            border: 1px solid rgba(0, 229, 255, .2);
            color: var(--cyan)
        }

        .sc-c:hover {
            background: rgba(0, 229, 255, .15)
        }

        .sc-p {
            background: linear-gradient(135deg, var(--purple), var(--cyan));
            border: none;
            color: #000
        }

        .sc-p:hover {
            box-shadow: 0 8px 30px rgba(178, 77, 255, .3)
        }

        .sc-g {
            background: rgba(255, 215, 0, .08);
            border: 1px solid rgba(255, 215, 0, .2);
            color: var(--gold)
        }

        .sc-g:hover {
            background: rgba(255, 215, 0, .15)
        }

        .new-tag {
            display: inline-block;
            background: linear-gradient(135deg, var(--gold), var(--pink));
            color: #000;
            padding: .15rem .6rem;
            border-radius: 6px;
            font-size: .6rem;
            font-weight: 800;
            letter-spacing: 1px;
            margin-left: .5rem;
            vertical-align: middle
        }

        /* LIVE DEMO SECTION */
        .demo-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem
        }

        .demo-card {
            background: var(--card);
            border: 1px solid var(--bdr);
            border-radius: 16px;
            padding: 2rem;
            backdrop-filter: blur(10px)
        }

        .demo-card h3 {
            font-size: 1.2rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: .5rem
        }

        .demo-card h3 .tag {
            font-size: .6rem;
            padding: .2rem .5rem;
            border-radius: 4px;
            font-family: 'JetBrains Mono', monospace;
            letter-spacing: 1px
        }

        .tag-live {
            background: rgba(0, 255, 136, .1);
            color: var(--green)
        }

        .tag-soul {
            background: rgba(178, 77, 255, .1);
            color: var(--purple)
        }

        /* CHRONOS NEON GOLD GLASSMORPHISM */
        .chrono-zone { position: relative; overflow: hidden }
        .chrono-zone::before {
            content: '';
            position: absolute;
            top: -50%; left: -50%; width: 200%; height: 200%;
            background: conic-gradient(from 0deg, transparent, rgba(255,210,63,.06), transparent, rgba(255,180,0,.04), transparent);
            animation: cg-spin 12s linear infinite;
        }
        @keyframes cg-spin { to { transform: rotate(360deg) } }
        .chrono-zone .slbl { color: #FFD23F }
        .chrono-zone .stitle { background: linear-gradient(135deg, #FFD23F, #FFB700, #FFF4CC, #FFD23F); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text }

        .glass-gold {
            background: linear-gradient(135deg, rgba(255,210,63,.03), rgba(255,183,0,.02), rgba(12,12,22,.7));
            border: 1px solid rgba(255,210,63,.12);
            border-radius: 20px;
            padding: 2.2rem;
            backdrop-filter: blur(20px);
            position: relative;
            overflow: hidden;
            transition: all .5s cubic-bezier(.19,1,.22,1);
        }
        .glass-gold::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 20px;
            padding: 1px;
            background: linear-gradient(135deg, rgba(255,210,63,.3), transparent 40%, transparent 60%, rgba(255,183,0,.2));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
        }
        .glass-gold::after {
            content: '';
            position: absolute;
            top: -1px; right: -1px;
            width: 80px; height: 80px;
            background: radial-gradient(circle, rgba(255,210,63,.15), transparent 70%);
            pointer-events: none;
        }
        .glass-gold:hover {
            border-color: rgba(255,210,63,.25);
            box-shadow: 0 0 60px rgba(255,210,63,.08), 0 20px 60px rgba(0,0,0,.3), inset 0 1px 0 rgba(255,210,63,.1);
            transform: translateY(-4px);
        }
        .glass-gold h3 { display: flex; align-items: center; gap: .6rem; font-size: 1.15rem; margin-bottom: 1.2rem }
        .gold-tag {
            font-size: .55rem;
            padding: .25rem .65rem;
            border-radius: 100px;
            font-family: 'JetBrains Mono', monospace;
            letter-spacing: 1.5px;
            font-weight: 700;
            text-transform: uppercase;
        }
        .gold-tag.live {
            background: linear-gradient(135deg, rgba(255,210,63,.15), rgba(255,183,0,.08));
            color: #FFD23F;
            border: 1px solid rgba(255,210,63,.2);
            box-shadow: 0 0 12px rgba(255,210,63,.1);
        }
        .gold-metrics {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1.5rem;
            font-size: .85rem;
        }
        .gold-metric {
            padding: .8rem;
            background: rgba(255,210,63,.02);
            border: 1px solid rgba(255,210,63,.06);
            border-radius: 10px;
        }
        .gold-metric .gm-l {
            font-size: .6rem;
            color: rgba(255,210,63,.5);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-family: 'JetBrains Mono', monospace;
            margin-bottom: .3rem;
        }
        .gold-metric .gm-v { font-weight: 700; font-size: 1rem }
        .gold-metric .gm-v.neon-gold { color: #FFD23F; text-shadow: 0 0 20px rgba(255,210,63,.3) }
        .gold-metric .gm-v.neon-green { color: var(--green); text-shadow: 0 0 15px rgba(0,255,136,.2) }

        .gold-tbl {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 4px;
            margin: .5rem 0;
            font-size: .82rem;
        }
        .gold-tbl th {
            text-align: left;
            padding: .6rem .7rem;
            color: rgba(255,210,63,.4);
            font-size: .6rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-family: 'JetBrains Mono', monospace;
            border: none;
        }
        .gold-tbl td {
            padding: .65rem .7rem;
            background: rgba(255,210,63,.015);
            border-top: 1px solid rgba(255,210,63,.04);
            border-bottom: 1px solid rgba(255,210,63,.04);
        }
        .gold-tbl td:first-child { border-left: 1px solid rgba(255,210,63,.04); border-radius: 8px 0 0 8px }
        .gold-tbl td:last-child { border-right: 1px solid rgba(255,210,63,.04); border-radius: 0 8px 8px 0 }
        .gold-tbl tr:hover td { background: rgba(255,210,63,.035); }
        .gold-tbl .dir-dn { color: #FF6B6B }
        .gold-tbl .dir-sw { color: rgba(255,210,63,.6) }
        .gold-tbl .chg { font-family: 'JetBrains Mono', monospace; font-weight: 600 }
        .gold-tbl .chg.neg { color: #FF6B6B }
        .gold-tbl .conf-bar {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            font-family: 'JetBrains Mono', monospace;
        }
        .conf-fill {
            width: 40px; height: 4px;
            background: rgba(255,255,255,.06);
            border-radius: 2px;
            overflow: hidden;
        }
        .conf-fill span {
            display: block;
            height: 100%;
            border-radius: 2px;
            background: linear-gradient(90deg, #FFD23F, #FFB700);
        }
        .state-badge {
            padding: .2rem .5rem;
            border-radius: 4px;
            font-size: .7rem;
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
            letter-spacing: .5px;
        }
        .state-badge.s-trans { background: rgba(255,210,63,.08); color: #FFD23F; border: 1px solid rgba(255,210,63,.15) }
        .state-badge.s-true { background: rgba(0,255,136,.06); color: var(--green); border: 1px solid rgba(0,255,136,.12) }
        .state-badge.s-para { background: rgba(178,77,255,.08); color: var(--purple); border: 1px solid rgba(178,77,255,.15); animation: para-pulse 2s infinite }
        @keyframes para-pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(178,77,255,.15) } 50% { box-shadow: 0 0 12px 2px rgba(178,77,255,.1) } }

        .paradox-alert {
            margin-top: 1rem;
            padding: 1rem 1.2rem;
            background: linear-gradient(135deg, rgba(178,77,255,.04), rgba(255,210,63,.02));
            border: 1px solid rgba(178,77,255,.12);
            border-left: 3px solid var(--purple);
            border-radius: 0 10px 10px 0;
            font-size: .8rem;
        }
        .paradox-alert strong {
            color: var(--purple);
            display: flex;
            align-items: center;
            gap: .4rem;
            margin-bottom: .3rem;
            font-size: .75rem;
            letter-spacing: .5px;
        }
        .paradox-alert p { color: var(--dim); line-height: 1.5 }
        .gold-targets {
            margin-top: .8rem;
            padding: .6rem .8rem;
            background: rgba(255,210,63,.02);
            border: 1px solid rgba(255,210,63,.06);
            border-radius: 8px;
            font-family: 'JetBrains Mono', monospace;
            font-size: .72rem;
            color: rgba(255,210,63,.5);
            display: flex;
            align-items: center;
            gap: .5rem;
        }
        .gold-targets .tgt-arr { color: rgba(255,210,63,.3) }

        /* CODE BLOCKS */
        .code {
            background: rgba(8, 8, 14, .9);
            border: 1px solid var(--bdr);
            border-radius: 12px;
            padding: 1.5rem;
            font-family: 'JetBrains Mono', monospace;
            font-size: .78rem;
            line-height: 1.8;
            overflow-x: auto
        }

        .code .cm {
            color: var(--mut)
        }

        .code .kw {
            color: var(--purple)
        }

        .code .st {
            color: var(--green)
        }

        .code .sp {
            color: var(--cyan)
        }

        .code .vl {
            color: var(--gold)
        }

        .code .fn {
            color: var(--pink)
        }

        /* CATUSKOTI */
        .cat-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            margin: 2rem 0
        }

        .cat-cell {
            padding: 1.5rem 1rem;
            border-radius: 12px;
            text-align: center;
            border: 1px solid var(--bdr);
            transition: all .3s
        }

        .cat-cell:hover {
