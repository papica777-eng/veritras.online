{
  "name": "qantum-training-framework",
  "version": "18.0.0",
  "description": "🧠 SOVEREIGN SINGULARITY - AI-Powered Testing Framework with Self-Healing, Swarm Intelligence, and Predictive QA",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "start:framework": "node index.js",
    "test": "node tests/unit/phase1-core.test.js",
    "test:unit": "node tests/unit/phase1-core.test.js",
    "test:phase1": "node -e \"const {Phase1Orchestrator} = require('./phase1-index'); const p = new Phase1Orchestrator(); p.initialize().then(() => p.runTests()).then(console.log)\"",
    "test:phase2": "node -e \"const {Phase2Orchestrator} = require('./phase2-index'); const p = new Phase2Orchestrator(); p.initialize().then(() => p.runTests()).then(console.log)\"",
    "test:phase3": "node -e \"const {Phase3Orchestrator} = require('./phase3-index'); const p = new Phase3Orchestrator(); p.initialize().then(() => p.runTests()).then(console.log)\"",
    "test:jest": "NODE_OPTIONS=--experimental-vm-modules jest",
    "security:check": "node scripts/security-scan.js",
    "test:perf": "node scripts/performance-benchmark.js",
    "update:deps": "node scripts/auto-update-deps.js",
    "test:mutation": "node scripts/mutation-test.js",
    "test:all": "node -e \"const {initialize} = require('./index'); initialize().then(s => s.runComprehensiveTests()).then(console.log)\"",
    "test:deploy": "node tests/auto-sync-deploy.test.js",
    "docs": "node -e \"const {SelfDocEngine} = require('./docs/self-documenting'); const e = new SelfDocEngine(); e.documentDirectory('.').then(console.log)\"",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.js\"",
    "analyze": "ts-node scripts/deduplicate-analyze.ts",
    "absorb": "ts-node scripts/neural-core-magnet.ts",
    "integrate": "ts-node scripts/qantum-integrator.ts",
    "orchestrate": "ts-node scripts/master-orchestrator.ts",
    "deploy": "node scripts/auto-sync-deploy.js",
    "deploy:status": "node scripts/auto-sync-deploy.js --status",
    "branch:setup": "node scripts/branch-manager.js setup",
    "branch:status": "node scripts/branch-manager.js status",
    "branch:promote": "node scripts/branch-manager.js promote",
    "branch:cleanup": "node scripts/branch-manager.js cleanup"
  },
